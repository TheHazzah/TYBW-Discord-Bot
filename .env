# ── Required ──────────────────────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# The ID of the channel where announcements will be posted
# Right-click a channel in Discord → "Copy Channel ID" (enable Developer Mode first)
DISCORD_CHANNEL_ID=1506621179257946122

# ── Optional ──────────────────────────────────────────────────────────────────
# How often to check nyaa.si for new uploads, in milliseconds
# Default: 300000 (5 minutes). Don't go below 60000 (1 min) to avoid rate limits.
CHECK_INTERVAL_MS=300000
